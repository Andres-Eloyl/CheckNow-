# ──────────────────────────────────────────────
# CheckNow! — Environment Variables
# Copy this file to .env and update values
# ──────────────────────────────────────────────

# Database
DATABASE_URL=postgresql+asyncpg://checknow:checknow@localhost:5432/checknow
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=change-me-to-random-64-chars-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=1440
JWT_REFRESH_EXPIRE_DAYS=7
AES_KEY=change-me-to-32-byte-key-base64=

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# BCV Exchange Rates
BCV_API_URL=https://pydolarve.org/api/v1/dollar?monitor=bcv
BCV_CACHE_TTL_HOURS=4

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Super Admin
SUPER_ADMIN_EMAIL=admin@checknow.app
SUPER_ADMIN_PASSWORD=change-me-in-production

# Sentry (leave empty to disable)
SENTRY_DSN=

# App Settings
ENVIRONMENT=development
MAX_FILE_SIZE_MB=5
SESSION_EXPIRY_HOURS=24
SPLIT_EXPIRY_MINUTES=5
SCREENSHOT_PURGE_DAYS=7
