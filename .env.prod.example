# CheckNow! — Production Environment Template
# Copy this file to '.env' on your production server (VPS/Cloud)
# Do NOT commit your actual .env file to version control.

# Core Application Settings
APP_NAME=CheckNow!
ENVIRONMENT=production

# Supabase Database (Session Pooler URL recommended for serverless/VPS)
# Example: postgresql://postgres.[project]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL=your_supabase_connection_string_here

# Supabase API (For Admin access if needed later)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Redis (Inside docker-compose, this is mapped automatically via service name)
REDIS_URL=redis://redis:6379/0

# Security Keys
# Generate a strong 32+ char key: openssl rand -hex 32
SECRET_KEY=your_super_secret_jwt_key_here
# Generate a strong 32+ char key for AES Encryption (Reference codes)
AES_KEY=your_32_character_aes_encryption_key_here

# Sentry Error Tracking (Optional but highly recommended)
# Get this from sentry.io
SENTRY_DSN=https://your_sentry_dsn_here
